# apps/game-server/.env
# Copy this file to .env and fill in your values

# PORT is injected by Render automatically in production; only set locally.
PORT=3001

# CORS_ORIGIN: comma-separated list of allowed FRONTEND origins (no trailing slashes).
# These are where your Next.js frontend is served from — NOT the game server's own port.
#
# LOCALHOST MODE (same machine only):
#   CORS_ORIGIN=http://localhost:3000
#
# LAN/IP MODE (allow your laptop + other devices on local network):
#   CORS_ORIGIN=http://localhost:3000,http://192.168.1.102:3000
#   (replace 192.168.1.102 with your machine's actual LAN IP)
#
# PRODUCTION: use your Vercel deployment URL
CORS_ORIGIN=http://localhost:3000,https://your-app.vercel.app

# Optional: allow all Vercel preview deployments (*.vercel.app)
CORS_ALLOW_VERCEL_PREVIEWS=false

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
